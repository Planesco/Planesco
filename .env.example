# Resend (https://resend.com) – required for contact form email
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: override where form submissions are sent
CONTACT_EMAIL=info@planesco.com

# Optional: "from" address (must be verified in Resend for production)
# RESEND_FROM_EMAIL=notifications@yourdomain.com

# Site URL for SEO (canonical URLs, sitemap, Open Graph). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://planesco.com
